{
    "uuid": "org.waywallen.gnome@waywallen.io",
    "name": "Waywallen",
    "description": "Wallpaper plugin for the waywallen daemon.",
    "url": "https://github.com/waywallen",
    "version": @WW_GNOME_VERSION@,
    "version-name": "@PROJECT_VERSION@",
    "shell-version": [
        "48",
        "49",
        "50"
    ],
    "settings-schema": "org.gnome.shell.extensions.waywallen",
    "gettext-domain": "waywallen-gnome",
    "session-modes": ["user", "unlock-dialog"]
}
